{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "noEmit": true,
    "types": [
      "node",
      "vitest/globals",
      "express",
      "multer"
    ]
  },
  "include": [
    "src",
    "tests",
    "vitest.config.ts"
  ]
}
