{
  "name": "flowstate",
  "private": true,
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "bun run dev:server",
    "dev:client": "bun run --cwd client dev",
    "dev:server": "bun run --cwd server dev",
    "build": "bun run build:client && bun run build:server",
    "build:client": "bun run --cwd client build",
    "build:server": "bun run --cwd server build",
    "test": "bun run test:client && bun run test:server",
    "test:client": "bun run --cwd client test",
    "test:server": "bun run --cwd server test",
    "lint": "bun run lint:client && bun run lint:server",
    "lint:client": "bun run --cwd client lint",
    "lint:server": "bun run --cwd server lint",
    "format": "bunx prettier --write ."
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource/fraunces": "^5.2.9",
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "@fontsource/merriweather": "^5.2.11",
    "@fontsource/space-grotesk": "^5.2.10"
  }
}
